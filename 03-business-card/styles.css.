body {
  background-color: rosybrown;
  font-family: Arial, sans-serif;
}
.profile-image {
  max-width: 100%;
  height: auto;
  display: block;
}
.business-card {
  width: 300px;
  background-color: navy;
  padding: 20px;
  margin-top: 100px;
  text-align: center;
  font-size: 16px;
  margin-left: auto;
  margin-right: auto;
}
.full-name {
  color: gold;
}
.designation {
  color: gold;
}
.company {
  color: gold;
}
.email {
  color: gold;
}
.number {
  color: gold;
}
.portfolio-link {
  color: red;
}
h2 {
  color: gold;
}
a {
  text-decoration: none;
  color: silver;
}
a:hover {
  color: gold;
}
a:active {
  color: gold;
}
p {
  margin-top: 5px;
  margin-bottom: 5px
}
